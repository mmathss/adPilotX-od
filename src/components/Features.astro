---
import { SITE_DATA } from '../data/siteData';

interface Props {
  videoUrl?: string;
}

const { videoUrl: propVideoUrl } = Astro.props;
const videoData = {
  ...SITE_DATA.video_demo,
  videoUrl: propVideoUrl ?? SITE_DATA.video_demo.videoUrl
};
---
<section id="funciones">
  <div class="container">
    <h2>Mira cómo optimizamos tu presupuesto</h2>
    
    <div id="demo-window-container">
      {videoData.videoUrl ? (
        <div class="demo-window reveal glass">
          <div class="window-body" style="padding: 0; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #000; min-height: 380px; position: relative;">
            <video id="demo-video-player" src={videoData.videoUrl} poster={videoData.thumbnailUrl || ''} style="width: 100%; height: 100%; object-fit: cover;" playsinline></video>
            
            <button class="play-btn" id="demo-video-play-btn" aria-label="Reproducir video" style="position: absolute; z-index: 10; cursor: pointer; transition: all 0.3s var(--ease-out);">
              <svg id="play-btn-icon" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" style="transform: translateX(2px);"><path d="M8 5v14l11-7z"/></svg>
            </button>

            <div class="video-controls-bar" style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 5; background: rgba(10, 10, 12, 0.45); backdrop-filter: blur(12px);">
              <button class="control-play-mini" id="demo-video-play-mini" aria-label="Reproducir" style="cursor: pointer;"><svg id="play-mini-icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
              <div class="video-scrubber-container">
                <div class="video-progress-bar" id="demo-video-progress" style="width: 0%;"></div>
              </div>
              <div class="video-time" id="demo-video-time">0:00 / 0:00</div>
            </div>
          </div>
        </div>
      ) : (
        <div class="demo-window reveal glass">
          <div class="window-body">
            <div class="video-header-bar">
              <div class="video-badge">{videoData.badge || 'DEMO DE PLATAFORMA'}</div>
              <div style="font-size: 0.8rem; font-weight: 500; opacity: 0.8; letter-spacing: 0.05em; text-transform: uppercase;">{videoData.version || 'adpilotx_dashboard_v1.4'}</div>
            </div>

            <div class="saas-mockup">
              <div class="saas-sidebar">
                <div class="saas-logo-pill"></div>
                <div class="saas-nav-item active"></div>
                <div class="saas-nav-item" style="margin-top: 4px;"></div>
                <div class="saas-nav-item" style="margin-top: 4px;"></div>
                <div class="saas-nav-item" style="margin-top: 4px;"></div>
              </div>
              
              <div class="saas-content">
                <div class="saas-topbar">
                  <div class="saas-crumb">{videoData.crumb || 'Campañas / Escala Proactiva'}</div>
                  <div class="saas-status-badge">{videoData.status || 'Optimizando 24/7'}</div>
                </div>
                
                <div class="saas-metrics-row">
                  <div class="saas-card">
                    <span class="saas-card-label">Presupuesto Diario</span>
                    <span class="saas-card-val">{videoData.budget || '$450.00'}</span>
                  </div>
                  <div class="saas-card">
                    <span class="saas-card-label">ROAS Promedio</span>
                    <span class="saas-card-val" style="color: #10b981;">{videoData.roas || '5.2x'}</span>
                  </div>
                  <div class="saas-card">
                    <span class="saas-card-label">Costo por Lead</span>
                    <span class="saas-card-val">{videoData.cpl || '$8.12'}</span>
                  </div>
                </div>
                
                <div class="saas-chart-card">
                  <div class="saas-chart-header">
                    <div>
                      <span class="saas-card-label" style="display:block; margin-bottom:2px;">Rendimiento de Conversión</span>
                      <strong style="font-size: 0.95rem; font-family:'Outfit',sans-serif;">{videoData.chartPercentage || '+42.8% este mes'}</strong>
                    </div>
                    <div style="display:flex; gap: 6px;">
                      <span class="saas-dot-indicator" style="background:#2f62f6;"></span>
                      <span class="saas-dot-indicator" style="background:#6366f1;"></span>
                    </div>
                  </div>
                  <div class="saas-svg-container">
                    <svg viewBox="0 0 500 120" preserveAspectRatio="none" style="width:100%; height:100%; overflow:visible;">
                      <defs>
                        <linearGradient id="chart-grad-saas" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.25"/>
                          <stop offset="100%" stop-color="var(--primary)" stop-opacity="0"/>
                        </linearGradient>
                      </defs>
                      <line x1="0" y1="30" x2="500" y2="30" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                      <line x1="0" y1="60" x2="500" y2="60" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                      <line x1="0" y1="90" x2="500" y2="90" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                      
                      <path d="M0,110 Q50,90 100,95 T200,60 T300,45 T400,20 T500,10 L500,120 L0,120 Z" fill="url(#chart-grad-saas)" />
                      <path d="M0,110 Q50,90 100,95 T200,60 T300,45 T400,20 T500,10" fill="none" stroke="var(--primary)" stroke-width="3" stroke-linecap="round"/>
                      
                      <circle cx="300" cy="45" r="5" fill="#6366f1" stroke="white" stroke-width="2" />
                      <circle cx="500" cy="10" r="5" fill="#2f62f6" stroke="white" stroke-width="2" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>

            <button class="play-btn" aria-label="Reproducir video"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" style="transform: translateX(2px);"><path d="M8 5v14l11-7z"/></svg></button>

            <div class="video-controls-bar">
              <button class="control-play-mini" aria-label="Reproducir"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
              <div class="video-scrubber-container">
                <div class="video-progress-bar" style="width: 35%;"></div>
              </div>
              <div class="video-time">0:42 / 2:15</div>
            </div>
          </div>
        </div>
      )}
    </div>

    <div class="metrics reveal" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; margin-top: 40px;">
      <div class="bullet" style="display:flex; gap:12px; align-items:flex-start;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--primary)" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        <div><strong>Setup rápido</strong><br><small>Menos de 60 segundos</small></div>
      </div>
      <div class="bullet" style="display:flex; gap:12px; align-items:flex-start;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--primary)" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        <div><strong>A/B Testing</strong><br><small>Variantes automáticas</small></div>
      </div>
      <div class="bullet" style="display:flex; gap:12px; align-items:flex-start;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--primary)" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        <div><strong>Copys persuasivos</strong><br><small>Optimización constante</small></div>
      </div>
      <div class="bullet" style="display:flex; gap:12px; align-items:flex-start;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--primary)" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        <div><strong>Sin contratos</strong><br><small>Cancela cuando quieras</small></div>
      </div>
    </div>
  </div>
</section>
