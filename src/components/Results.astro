---
interface Testimonial {
  quote: string;
  author: string;
  role: string;
  avatarLetter: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---
<section id="resultados" class="results-section">
  <div class="container">
    <h2>Resultados reales</h2>
    <div class="data-banner reveal glass">
      <div class="metrics">
        <div class="m-item">
          <h3>3.64x</h3>
          <p>ROAS Medio</p>
          <div class="sparkline-container">
            <svg viewBox="0 0 200 60" width="100%" height="100%" preserveAspectRatio="none">
              <defs>
                <linearGradient id="sparkGrad-1" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.3"></stop>
                  <stop offset="100%" stop-color="var(--primary)" stop-opacity="0"></stop>
                </linearGradient>
              </defs>
              <path d="M 0 50 Q 25 45 50 35 T 100 20 T 150 25 T 200 5 L 200 60 L 0 60 Z" fill="url(#sparkGrad-1)"></path>
              <path d="M 0 50 Q 25 45 50 35 T 100 20 T 150 25 T 200 5" fill="none" stroke="var(--primary)" stroke-width="2"></path>
            </svg>
          </div>
        </div>
        <div class="m-item">
          <h3>4.18%</h3>
          <p>CTR Medio</p>
          <div class="sparkline-container">
            <svg viewBox="0 0 200 60" width="100%" height="100%" preserveAspectRatio="none">
              <defs>
                <linearGradient id="sparkGrad-2" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--secondary)" stop-opacity="0.3"></stop>
                  <stop offset="100%" stop-color="var(--secondary)" stop-opacity="0"></stop>
                </linearGradient>
              </defs>
              <path d="M 0 45 C 30 50, 60 20, 90 35 C 120 50, 150 10, 200 8 L 200 60 L 0 60 Z" fill="url(#sparkGrad-2)"></path>
              <path d="M 0 45 C 30 50, 60 20, 90 35 C 120 50, 150 10, 200 8" fill="none" stroke="var(--secondary)" stroke-width="2"></path>
            </svg>
          </div>
        </div>
        <div class="m-item">
          <h3>+64.8%</h3>
          <p>Ventas Directas</p>
          <div class="sparkline-container">
            <svg viewBox="0 0 200 60" width="100%" height="100%" preserveAspectRatio="none">
              <defs>
                <linearGradient id="sparkGrad-3" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.3"></stop>
                  <stop offset="100%" stop-color="var(--primary)" stop-opacity="0"></stop>
                </linearGradient>
              </defs>
              <path d="M 0 55 Q 40 45 80 48 T 140 20 T 200 3 L 200 60 L 0 60 Z" fill="url(#sparkGrad-3)"></path>
              <path d="M 0 55 Q 40 45 80 48 T 140 20 T 200 3" fill="none" stroke="var(--primary)" stroke-width="2"></path>
            </svg>
          </div>
        </div>
      </div>
      <div class="data-text">
        <p class="reveal-scrub">Nuestra tecnología no solo crea anuncios. Aprende qué funciona y escala las campañas rentables automáticamente para maximizar cada dólar invertido.</p>
      </div>
    </div>

    <div class="testi-grid" id="testimonials-container">
      {testimonials.map((testi) => (
        <div class="testi-card reveal glass">
          <div>
            <div class="testi-stars">
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>
            <p class="testi-quote">"{testi.quote}"</p>
          </div>
          <div class="testi-author">
            <div class="testi-img">{testi.avatarLetter}</div>
            <div class="testi-info">
              <h4>{testi.author}</h4>
              <p class="text-muted">{testi.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
