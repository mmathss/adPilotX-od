---
---
<section id="pasos">
  <div class="container">
    <h2 class="text-center">Crear campañas ahora es simple</h2>
    <p class="subtitle text-center">Tres pasos para poner el sistema a trabajar para ti.</p>

    <div class="steps-row">
      <!-- Step 1: Brief -->
      <div class="step-card reveal">
        <div>
          <div class="step-num">1</div>
          <h3>Brief estratégico</h3>
          <p class="text-muted" style="margin-bottom: 24px;">Responde preguntas sobre tu producto y audiencia para definir la base de tus campañas.</p>
        </div>
        <div class="step-preview glass">
          <div style="width: 100%; display: flex; flex-direction: column; gap: 10px; text-align: left;">
            <div style="display:flex; justify-content:space-between; align-items:center;">
              <span style="font-size: 0.6rem; color: var(--muted); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Paso 1: Tu Nicho</span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--primary);"></span>
            </div>
            <div style="padding: 10px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--glass-border); border-radius: 8px; font-size: 0.65rem; color: var(--fg); display: flex; align-items: center; justify-content: space-between;">
              <span>E-commerce de Moda Premium</span>
              <span style="font-size: 0.55rem; color: var(--primary); font-weight: 700;">OK</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top: 4px;">
              <span style="font-size: 0.6rem; color: var(--muted); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;">Paso 2: Objetivo</span>
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--muted); opacity: 0.3;"></span>
            </div>
            <div style="padding: 10px; background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--glass-border); border-radius: 8px; font-size: 0.65rem; color: var(--muted);">
              Maximizar ROAS...
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Generation -->
      <div class="step-card reveal">
        <div>
          <div class="step-num">2</div>
          <h3>Generación masiva</h3>
          <p class="text-muted" style="margin-bottom: 24px;">Creamos docenas de opciones creativas y estructuras de segmentación en segundos.</p>
        </div>
        <div class="step-preview glass" style="padding: 14px;">
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; height: 100%;">
            <!-- Micro Variant Card A -->
            <div style="background: linear-gradient(135deg, rgba(47, 98, 246, 0.1), rgba(99, 102, 241, 0.1)); border: 1px solid rgba(47, 98, 246, 0.2); border-radius: 8px; padding: 10px; display: flex; flex-direction: column; justify-content: space-between; text-align: left; position: relative;">
              <span style="font-size: 0.55rem; font-weight: 800; background: var(--primary); color: white; padding: 1px 4px; border-radius: 3px; align-self: flex-start; letter-spacing: 0.02em;">VAR A</span>
              <div style="height: 4px; background: var(--primary); width: 80%; border-radius: 2px; margin-top: 14px;"></div>
              <div style="height: 4px; background: var(--muted); width: 50%; border-radius: 2px; margin-top: 4px; opacity: 0.4;"></div>
            </div>
            <!-- Micro Variant Card B -->
            <div style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(47, 98, 246, 0.05)); border: 1px solid var(--glass-border); border-radius: 8px; padding: 10px; display: flex; flex-direction: column; justify-content: space-between; text-align: left;">
              <span style="font-size: 0.55rem; font-weight: 800; background: var(--secondary); color: white; padding: 1px 4px; border-radius: 3px; align-self: flex-start; letter-spacing: 0.02em;">VAR B</span>
              <div style="height: 4px; background: var(--secondary); width: 70%; border-radius: 2px; margin-top: 14px;"></div>
              <div style="height: 4px; background: var(--muted); width: 40%; border-radius: 2px; margin-top: 4px; opacity: 0.4;"></div>
            </div>
            <!-- Micro Variant Card C -->
            <div style="background: linear-gradient(135deg, rgba(47, 98, 246, 0.05), rgba(99, 102, 241, 0.05)); border: 1px dashed var(--glass-border); border-radius: 8px; padding: 10px; display: flex; flex-direction: column; justify-content: space-between; text-align: left; opacity: 0.6;">
              <span style="font-size: 0.55rem; font-weight: 800; background: var(--muted); color: white; padding: 1px 4px; border-radius: 3px; align-self: flex-start; letter-spacing: 0.02em;">VAR C</span>
              <div style="height: 4px; background: var(--muted); width: 60%; border-radius: 2px; margin-top: 14px;"></div>
              <div style="height: 4px; background: var(--muted); width: 30%; border-radius: 2px; margin-top: 4px; opacity: 0.4;"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Optimization -->
      <div class="step-card reveal">
        <div>
          <div class="step-num">3</div>
          <h3>Optimización activa</h3>
          <p class="text-muted" style="margin-bottom: 24px;">Ajustamos pujas y segmentación descartando lo que no genera retorno de inversión.</p>
        </div>
        <div class="step-preview glass">
          <div style="width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: space-between; position: relative;">
            <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.6rem; color:var(--muted); font-family:'Outfit',sans-serif; font-weight:700; width:100%; margin-bottom: 4px; letter-spacing:0.05em;">
              <span>RENDIMIENTO</span>
              <span style="color:#10b981;">+340% ROAS</span>
            </div>
            <div style="flex:1; display:flex; align-items:flex-end; padding-bottom: 0;">
              <svg viewBox="0 0 100 45" preserveAspectRatio="none" style="width: 100%; height: 80%; overflow: visible;">
                <polyline fill="none" stroke="var(--primary)" stroke-width="3" points="0,40 20,30 40,35 60,10 80,15 100,2" stroke-linecap="round" stroke-linejoin="round"/>
                <path fill="url(#chart-grad-steps)" d="M0,40 L20,30 L40,35 L60,10 L80,15 L100,2 L100,45 L0,45 Z"/>
                <circle cx="100" cy="2" r="3" fill="#2f62f6" stroke="white" stroke-width="1"/>
                <defs>
                  <linearGradient id="chart-grad-steps" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="var(--primary)" stop-opacity="0"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
